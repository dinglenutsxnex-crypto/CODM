<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18FFFFFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="50%">
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF" />
            <corners android:topLeftRadius="22dp" android:topRightRadius="22dp" android:bottomLeftRadius="0dp" android:bottomRightRadius="0dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#55FFFFFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
